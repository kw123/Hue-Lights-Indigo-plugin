<?xml version="1.0"?>
<MenuItems>
	<MenuItem id="menu1">
		<Name>Reload Hue Bridge Config</Name>
		<CallbackMethod>updateAllHueListsForce</CallbackMethod>
	</MenuItem>
	<MenuItem id="sep1" />
	<MenuItem id="savePreset">
		<Name>Save Preset...</Name>
		<CallbackMethod>savePreset</CallbackMethod>
		<ConfigUI>

			<Field type="menu" id="deviceId"
				defaultValue=""
			>
				<Label>Hue Device:</Label>
				<List
					class="self"
					filter="no"
					method="bulbAndGroupDeviceListGenerator"
				/>
			</Field>

			<Field type="label" id="deviceLabel"
				alignWithControl="true"
				fontSize="small"
				fontColor="darkgray"
			>
				<Label>Select the Hue device whose current settings you'd like to save to a Preset. The settings can be restored to any compatible Hue device at a later time.</Label>
			</Field>

			<Field type="menu" id="presetId"
				defaultValue=""
			>
				<Label>Preset:</Label>
				<List
					class="self"
					method="presetListGenerator"
				/>
			</Field>

			<Field type="label" id="presetLabel"
				alignWithControl="true"
				fontSize="small"
				fontColor="darkgray"
			>
				<Label>Select the Preset in which the above device's current settings should be stored. Presets with an asterisk (*) next to them have data already saved in them. Selecting one of these Presets will overwrite the data saved in that Preset.</Label>
			</Field>

			<Field type="textfield" id="presetName"
				defaultValue=""
			>
				<Label>Preset Name:</Label>
			</Field>

			<Field type="label" id="nameLabel"
				alignWithControl="true"
				fontSize="small"
				fontColor="darkgray"
			>
				<Label>Optionally assign a name to this Preset.</Label>
			</Field>

			<Field type="textfield" id="rate">
				<Label>Ramp Rate:</Label>
			</Field>

			<Field type="label" id="labelRate"
				alignWithControl="true"
				fontSize="small"
				fontColor="darkgray"
			>
				<Label>(0 - 540 seconds)
0 = instant
Save a Ramp Rate (transition time) to be used when recalling this Preset, accurate to 0.1 seconds.</Label>
			</Field>
		</ConfigUI>
	</MenuItem>
	<MenuItem id="recallPreset">
		<Name>Recall Preset...</Name>
		<CallbackMethod>recallPreset</CallbackMethod>
		<ConfigUI>

			<Field type="menu" id="deviceId"
				defaultValue=""
			>
				<Label>Hue Device:</Label>
				<List
					class="self"
					filter="no"
					method="bulbAndGroupDeviceListGenerator"
				/>
			</Field>

			<Field type="label" id="deviceLabel"
				alignWithControl="true"
				fontSize="small"
				fontColor="darkgray"
			>
				<Label>Select the Hue device to which the Preset should be applied.</Label>
			</Field>

			<Field type="menu" id="presetId"
				defaultValue=""
			>
				<Label>Preset:</Label>
				<List
					class="self"
					method="presetListGenerator"
				/>
			</Field>

			<Field type="label" id="presetLabel"
				alignWithControl="true"
				fontSize="small"
				fontColor="darkgray"
			>
				<Label>Select the Preset that should be applied to the device. Presets with an asterisk (*) next to them have data saved in them.</Label>
			</Field>

			<Field type="textfield" id="rate">
				<Label>Ramp Rate:</Label>
			</Field>

			<Field type="label" id="labelRate"
				alignWithControl="true"
				fontSize="small"
				fontColor="darkgray"
			>
				<Label>(0 - 540 seconds)
0 = instant
Optionally override this Preset's saved Ramp Rate (transition time). This overrides the device's default rate as well. Ramp Rates are accurate to 0.1 seconds.</Label>
			</Field>
		</ConfigUI>
	</MenuItem>
	<MenuItem id="sep2" />
	<MenuItem id="setSensitivityV2">
		<Name>Set Sensitivity of Sensor (pro Bridge)...</Name>
		<ConfigUI>

			<Field type="label" id="instructions1"
				fontSize="small"
			>
				<Label>Hue Sensors hav the option to set senbsitivity</Label>
			</Field>

			<Field type="menu" id="sensorId">
				<Label>select Motion Sensor:</Label>
				<List
					class="self"
					method="sensorListGenerator"
					filter="hueMotionSensor,hueMotionArea"
					dynamicReload="false"
				/>
			</Field>

			<Field type="menu" id="sensitivity"
				defaultValue="2"
			>
				<Label>sensitivity:</Label>
				<List>
					<Option value="0">0, very Low </Option>
					<Option value="1">1, low </Option>
					<Option value="2">2, normal</Option>
					<Option value="3">3, high</Option>
					<Option value="4">4, very high</Option>
				</List>
			</Field>

			<Field type="button" id="doSet">
				<Label>Click to</Label>
				<Title>Set</Title>
				<CallbackMethod>setSensitivityV2</CallbackMethod>
			</Field>
		</ConfigUI>
	</MenuItem>
	<MenuItem id="activateScene">
		<Name>Activate Hue Scene (not pro Bridge)...</Name>
		<ConfigUI>

			<Field type="label" id="instructions1"
				fontSize="small"
			>
				<Label>Hue Scenes are stored on the Hue Bridge and can be activated.</Label>
			</Field>

			<Field type="menu" id="hubNumber">
				<Label>Hue Bridge Number:</Label>
				<List
					class="self"
					method="gwListGenerator"
					filter="active"
					dynamicReload="false"
				> </List>
			</Field>

			<Field type="button" id="confirmGWNumber">
				<Label>click to</Label>
				<Title>select Bridge Number</Title>
				<CallbackMethod>confirmGWNumber</CallbackMethod>
			</Field>

			<Field type="menu" id="sceneId">
				<Label>select Scene:</Label>
				<List
					class="self"
					method="sceneListGenerator"
					dynamicReload="false"
				> </List>
			</Field>

			<Field type="button" id="doCreate">
				<Label>Click to</Label>
				<Title>execute action</Title>
				<CallbackMethod>activateScene</CallbackMethod>
			</Field>
		</ConfigUI>
	</MenuItem>
