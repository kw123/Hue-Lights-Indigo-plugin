	<MenuItem id="blinkV2menu">
		<Name>Send blink (pro Bridge)...</Name>
		<ConfigUI>

			<Field type="menu" id="devId"
				defaultValue=""
				tooltip=""
			>
				<Label>device to blink:</Label>
