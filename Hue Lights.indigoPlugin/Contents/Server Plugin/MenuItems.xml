					class="self"
					method="bulbAndGroupDeviceListGenerator"
					dynamicReload="true"
				/>
			</Field>

			<Field type="menu" id="blinkType"
				defaultValue="breathe"
				tooltip=""
			>
				<Label>what kind of action:</Label>
				<List>
					<Option value="breathe">breath 15 times (alert)</Option>
					<Option value="signal">blink</Option>
				</List>
			</Field>

			<Field type="menu" id="duration"
				defaultValue="2000"
				visibleBindingId="blinkType"
				visibleBindingValue="signal"
			>
				<Label>duration(secs):</Label>
				<List>
					<Option value="1000">1 </Option>
					<Option value="2000">2 </Option>
					<Option value="3000">3 </Option>
					<Option value="4000">4 </Option>
					<Option value="5000">5 </Option>
					<Option value="6000">6 </Option>
					<Option value="7000">7 </Option>
					<Option value="8000">8 </Option>
					<Option value="9000">9 </Option>
					<Option value="10000">10 </Option>
					<Option value="15000">15 </Option>
					<Option value="20000">20 </Option>
					<Option value="25000">25 </Option>
					<Option value="30000">30 </Option>
				</List>
			</Field>

			<Field type="menu" id="signal"
				defaultValue="on_off"
				visibleBindingId="blinkType"
				visibleBindingValue="signal"
			>
				<Label>signal type:</Label>
				<List>
					<Option value="on_off">on off </Option>
					<Option value="no_signal">off </Option>
				</List>
			</Field>

			<Field type="button" id="exeAction">
				<Label>Click to</Label>
				<Title>send alert</Title>
				<CallbackMethod>blinkV2</CallbackMethod>
			</Field>
		</ConfigUI>
	</MenuItem>
	<MenuItem id="effectV2">
		<Name>Effect (pro bridge)</Name>
		<ConfigUI>

			<Field type="menu" id="destinationType"
				defaultValue="light"
			>
				<Label>destination type::</Label>
				<List>
					<Option value="scene">scene</Option>
					<Option value="light">light</Option>
				</List>
			</Field>

			<Field type="menu" id="devId"
				defaultValue=""
				visibleBindingId="destinationType"
				visibleBindingValue="light"
			>
				<Label>light device to send the command to:</Label>
				<List
					class="self"
					method="lightsListGenerator"
					filter="oneLight"
					dynamicReload="false"
				/>
			</Field>

			<Field type="menu" id="sceneId"
				defaultValue=""
				visibleBindingId="destinationType"
				visibleBindingValue="scene"
			>
				<Label>scene to send the command to:</Label>
				<List
					class="self"
					method="generateSceneListV2"
					dynamicReload="false"
				/>
			</Field>

			<Field type="menu" id="effect"
				defaultValue="none"
				tooltip="Select a preset effect. Effect presets are usually built into the light device itself. These presets are not the same as Hue Lights presets."
			>
				<Label>Presets:</Label>
				<List>
					<Option value="no_effect">None = off</Option>
					<Option value="prism">prism</Option>
					<Option value="opal">opal</Option>
					<Option value="glisten">glisten</Option>
					<Option value="sparkle">sparkle</Option>
					<Option value="fire">fire</Option>
					<Option value="candle">candle</Option>
					<Option value="underwater">underwater</Option>
					<Option value="cosmos">cosmos</Option>
					<Option value="sunbeam">sunbeam</Option>
					<Option value="enchant">enchant</Option>
				</List>
			</Field>

			<Field type="label" id="labelEffect"
				alignWithControl="true"
				fontSize="small"
				fontColor="darkgray"
			>
				<Label>Select a Hue effect.</Label>
			</Field>

			<Field type="button" id="exeAction">
				<Label>Click to</Label>
				<Title>send effect</Title>
				<CallbackMethod>effectV2</CallbackMethod>
			</Field>

			<Field type="checkbox" id="debug"
				defaultValue="false"
			>
				<Label>debug:</Label>
			</Field>
		</ConfigUI>
	</MenuItem>
	<MenuItem id="powerOnBehaviourV2">
		<Name>Power-On Behaviour (pro bridge)...</Name>
		<ConfigUI>

			<Field type="label" id="instructions1">
				<Label>Set what a light does when physically power-cycled (wall switch off/on). Only individual lights are supported, not groups.</Label>
			</Field>

			<Field type="menu" id="devId"
				defaultValue=""
			>
				<Label>Light:</Label>
				<List
					class="self"
					method="lightsListGenerator"
					filter="oneLight"
					dynamicReload="true"
				/>
			</Field>

			<Field type="menu" id="preset"
				defaultValue="last_on_state"
			>
				<Label>When power is restored:</Label>
				<List>
					<Option value="last_on_state">Restore last on-state</Option>
					<Option value="safety">Safety (1% warm white)</Option>
					<Option value="powerfail">Restore if was on, else off</Option>
					<Option value="custom">Custom...</Option>
				</List>
			</Field>

			<Field type="menu" id="customOnMode"
				defaultValue="on"
				visibleBindingId="preset"
				visibleBindingValue="custom"
			>
				<Label>Turn on:</Label>
				<List>
					<Option value="on">Always on</Option>
					<Option value="toggle">Toggle (on if was off)</Option>
					<Option value="previous">Use previous on/off state</Option>
				</List>
			</Field>

			<Field type="menu" id="customBrightMode"
				defaultValue="previous"
				visibleBindingId="preset"
				visibleBindingValue="custom"
			>
				<Label>Brightness:</Label>
				<List>
					<Option value="previous">Restore previous brightness</Option>
					<Option value="dimming">Set a fixed value</Option>
				</List>
			</Field>

			<Field type="textfield" id="customBrightness"
				defaultValue="80"
				visibleBindingId="preset"
				visibleBindingValue="custom"
			>
				<Label>Brightness % (1-100, used when "Set a fixed value"):</Label>
			</Field>

			<Field type="menu" id="customColorMode"
				defaultValue="previous"
				visibleBindingId="preset"
				visibleBindingValue="custom"
			>
				<Label>Color:</Label>
				<List>
					<Option value="previous">Restore previous color</Option>
					<Option value="color_temperature">Set color temperature</Option>
				</List>
			</Field>

			<Field type="textfield" id="customMirek"
				defaultValue="366"
				visibleBindingId="preset"
				visibleBindingValue="custom"
			>
				<Label>Color temp mirek (153=cool, 500=warm, used when "Set color temperature"):</Label>
			</Field>

			<Field type="button" id="exeAction">
				<Label>Click to</Label>
				<Title>Set Power-On Behaviour</Title>
				<CallbackMethod>powerOnBehaviourV2</CallbackMethod>
			</Field>
		</ConfigUI>
	</MenuItem>
	<MenuItem id="sunriseTimedV2">
		<Name>Sunrise Timed Effect (pro bridge)...</Name>
		<ConfigUI>

			<Field type="label" id="instructions1">
				<Label>Start a sunrise wake-up simulation. The bridge manages the transition autonomously. Requires a newer Hue bulb that supports timed effects.</Label>
			</Field>

			<Field type="menu" id="devId"
				defaultValue=""
			>
				<Label>Light:</Label>
				<List
					class="self"
					method="lightsListGenerator"
					filter="oneLight"
					dynamicReload="true"
				/>
			</Field>

			<Field type="menu" id="action"
				defaultValue="start"
			>
				<Label>Action:</Label>
				<List>
					<Option value="start">Start sunrise</Option>
					<Option value="stop">Stop / cancel</Option>
				</List>
			</Field>

			<Field type="menu" id="duration"
				defaultValue="900000"
				visibleBindingId="action"
				visibleBindingValue="start"
			>
				<Label>Duration:</Label>
				<List>
					<Option value="60000">1 minute</Option>
					<Option value="120000">2 minutes</Option>
					<Option value="300000">5 minutes</Option>
					<Option value="600000">10 minutes</Option>
					<Option value="900000">15 minutes</Option>
					<Option value="1200000">20 minutes</Option>
					<Option value="1800000">30 minutes</Option>
					<Option value="2700000">45 minutes</Option>
					<Option value="3600000">60 minutes</Option>
				</List>
			</Field>

			<Field type="button" id="exeAction">
				<Label>Click to</Label>
				<Title>Send Sunrise Effect</Title>
				<CallbackMethod>sunriseTimedV2</CallbackMethod>
			</Field>
		</ConfigUI>
	</MenuItem>
	<MenuItem id="recallSmartSceneV2">
		<Name>Recall Smart Scene (pro bridge)...</Name>
		<ConfigUI>

			<Field type="label" id="instructions1">
				<Label>Smart scenes adapt brightness and color temperature to the time of day and natural light cycle. They are stored per room or zone on the bridge.</Label>
			</Field>

			<Field type="menu" id="sceneId"
				defaultValue=""
			>
				<Label>Smart Scene:</Label>
				<List
					class="self"
					method="generateSmartSceneListV2"
					dynamicReload="true"
				/>
			</Field>

			<Field type="menu" id="action"
				defaultValue="activate"
			>
				<Label>Action:</Label>
				<List>
					<Option value="activate">Activate</Option>
					<Option value="deactivate">Deactivate</Option>
				</List>
			</Field>

			<Field type="button" id="exeAction">
				<Label>Click to</Label>
				<Title>Recall Smart Scene</Title>
				<CallbackMethod>recallSmartSceneV2</CallbackMethod>
			</Field>
		</ConfigUI>
	</MenuItem>
	<MenuItem id="recallScene">
		<Name>Recall Hue Scene (not pro Bridge)...</Name>
		<CallbackMethod>recallScene</CallbackMethod>
		<ConfigUI>

			<Field type="label" id="instructions1"
				fontSize="small"
			>
				<Label>Hue Scenes are stored on the Hue Bridge and are organized here by which application created them.</Label>
			</Field>

			<Field type="menu" id="userId"
				defaultValue=""
				tooltip="Scene Creators are the applications on various devices that have connected to the Hue Bridge and created Scenes."
			>
				<Label>Scene Creator:</Label>
				<List
					class="self"
					method="usersListGenerator"
					dynamicReload="false"
				/>
				<CallbackMethod>usersListItemSelected</CallbackMethod>
			</Field>

			<Field type="label" id="userLabel"
				alignWithControl="true"
				fontSize="small"
				fontColor="darkgray"
			>
				<Label>Select a Scene Creator from the Bridge first (or use "All Scene Creators").
				</Label>
			</Field>

			<Field type="menu" id="sceneId"
				defaultValue=""
				tooltip="Scenes are stored on the Hue Bridge along with which application created them. Scenes in this menu were created by the Scene Creator selected above."
			>
				<Label>Scene:</Label>
				<List
					class="self"
					method="scenesListGenerator"
					dynamicReload="true"
